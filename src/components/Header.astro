---
import { SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";
import blogPlaceholder from "../assets/blog-placeholder-4.jpg";
---

<header>
	<nav class="flex gap-4 my-16">
		<a href="/"
			><img
				class="w-28 h-28"
				src={blogPlaceholder.src}
				alt="texture"
			/></a
		>
		<div class="flex flex-col justify-between">
			<h2 class="text-2xl font-medium"><a href="/">{SITE_TITLE}</a></h2>
			<p class="text-gray-600">A blog about whatever</p>

			<div class="internal-links">
				<HeaderLink href="/">Home</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
			</div>
		</div>
	</nav>
</header>
